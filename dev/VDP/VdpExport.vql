        employee_id:int (sourcetypeid = '4', sourcetyperadix = '10', sourcetypedecimals = '0', sourcetypesize = '6'), 
        first_name:text (sourcetypeid = '12', sourcetyperadix = '10', sourcetypesize = '20'), 
